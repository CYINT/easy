DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=easy.kuzuryu.ai,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://easy.kuzuryu.ai
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_DEFAULT_FROM_EMAIL=Easy <noreply@easy.kuzuryu.ai>

POSTGRES_DB=easy
POSTGRES_USER=easy
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://easy:change-me@db:5432/easy

EASY_HOSTNAME=easy.kuzuryu.ai
EASY_BIND_ADDRESS=127.0.0.1
EASY_HOST_PORT=18082
EASY_ATTACHMENT_MAX_BYTES=10485760
EASY_ATTACHMENT_ALLOWED_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain
EASY_UPLOAD_RATE_LIMIT=20/h
EASY_SECURITY_LOG_LEVEL=INFO

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
