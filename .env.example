DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=boards.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://boards.example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_DEFAULT_FROM_EMAIL=Easy <noreply@boards.example.com>

POSTGRES_DB=easy
POSTGRES_USER=easy
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://easy:change-me@db:5432/easy

EASY_HOSTNAME=boards.example.com
EASY_RELEASE_VERSION=0.1.0
EASY_RELEASE_COMMIT=unknown
EASY_BIND_ADDRESS=127.0.0.1
EASY_HOST_PORT=18082
EASY_ATTACHMENT_MAX_BYTES=10485760
EASY_ATTACHMENT_ALLOWED_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain
EASY_UPLOAD_RATE_LIMIT=20/h
EASY_SECURITY_LOG_LEVEL=INFO

EASY_ADMIN_EMAIL=admin@example.com
EASY_ADMIN_USERNAME=admin
EASY_ADMIN_PASSWORD=change-me-to-a-long-random-admin-password

EASY_ENABLE_GOOGLE_OAUTH=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
